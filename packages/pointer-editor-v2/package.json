    "@eslint/js": "^9.33.0",
    "@types/lodash": "^4.17.20",
    "@types/lodash.throttle": "^4.1.9",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
