{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@assets/*": ["assets/*"],
      "@apis": ["src/apis"],
      "@apis/*": ["src/apis/*"],
      "@components": ["src/components"],
      "@components/*": ["src/components/*"],
      "@contexts": ["src/contexts"],
      "@contexts/*": ["src/contexts/*"],
      "@hooks": ["src/hooks"],
      "@hooks/*": ["src/hooks/*"],
      "@types": ["src/types"],
      "@schema": ["src/types/api/schema.d.ts"],
      "@utils": ["src/utils"],
      "@utils/*": ["src/utils/*"],
      "@theme": ["src/theme"],
      "@theme/*": ["src/theme/*"],
      "@config": ["src/config"],
      "@config/*": ["src/config/*"],
      "@navigation": ["src/navigation"],
      "@navigation/*": ["src/navigation/*"],
      "@stores": ["src/stores"],
      "@stores/*": ["src/stores/*"],
      "@features": ["src/features"],
      "@features/*": ["src/features/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "nativewind-env.d.ts"]
}
